# Remote API config for split setup (Mac app → Windows infra)
# Copy to .env.remote and set your Windows IP:
#   cp .env.remote.example .env.remote
#   # Edit .env.remote and set WINDOWS_IP=192.168.1.105

WINDOWS_IP=192.168.1.105
# android = emulator, chrome = web, ios = iOS simulator
DEVICE=android
