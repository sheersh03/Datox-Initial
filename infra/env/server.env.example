ENV=local
APP_NAME=datox
API_PREFIX=/api

DATABASE_URL=postgresql+psycopg://datox:datox@postgres:5432/datox
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change_me_super_secret
JWT_ISSUER=datox
JWT_AUDIENCE=datox-mobile
ACCESS_TOKEN_MINUTES=10080

# Admin auth (dashboard login)
ADMIN_JWT_SECRET=change_me_admin_jwt_secret
ADMIN_ACCESS_TOKEN_TTL_SECONDS=900
ADMIN_REFRESH_TOKEN_TTL_SECONDS=604800
ADMIN_REFRESH_TOKEN_JTI_SALT=change_me_jti_salt
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5

OTP_DEV_BYPASS=true
OTP_TEST_CODE=123456
OTP_TTL_SECONDS=300

# MinIO (S3-compatible)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=datox
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_PUBLIC_BASE_URL=http://localhost:9000/datox

# RevenueCat
REVENUECAT_WEBHOOK_AUTH=dev_webhook_secret
REVENUECAT_MOCK_MODE=true

# Limits (free tier)
FREE_LIKES_PER_DAY=10
FREE_MATCHES_PER_DAY=5

# Location privacy
LOCATION_ROUNDING_KM=2.0

# CORS
CORS_ORIGINS=*
